# =============================================================================
# Financial Advisor AI Agent — .gitignore
# Goal: ignore environments, caches, secrets, and generated data — while
# KEEPING the knowledge/ folder STRUCTURE intact (via tracked .gitkeep files).
# =============================================================================
listen.md
# --- Python virtual environments --------------------------------------------
.venv/
venv/
env/
ENV/

# --- Python bytecode / build caches ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg-info/

# --- Configuration secrets ----------------------------------------------------
# Never commit real credentials. config.yaml holds the live API keys and is
# therefore UNTRACKED; config.example.yaml is the committed placeholder-only
# template (cp config.example.yaml config.yaml to get started). Prefer env vars
# — the loader reads them ahead of any file value.
config.yaml
.env
.env.*
*.secret
*.secret.yaml
secrets.yaml
config.local.yaml
config.*.local.yaml

# Scratch notebooks: they accumulate hardcoded keys in cell source/outputs
# (test_note.ipynb currently embeds a live DeepSeek key), so keep them local.
# Prefer reading credentials from config.yaml / env vars inside notebooks too.
*.ipynb
.ipynb_checkpoints/

# --- Local data caches --------------------------------------------------------
.cache/
*.cache
tmp/
*.tmp

# =============================================================================
# knowledge/ data layer
#   We track the directory skeleton + README/.gitkeep + the sample portfolio,
#   but ignore generated indexes, fetched market data, and logs.
# =============================================================================

# Vector DB: ignore ALL generated index contents, keep the folder + docs.
knowledge/vector_db/*
!knowledge/vector_db/.gitkeep
!knowledge/vector_db/README.md

# Market data: ignore fetched payloads, scrapes, and temporary logs; keep docs.
knowledge/market_data/*
!knowledge/market_data/.gitkeep
!knowledge/market_data/README.md
*.log

# Portfolios: ignore real customer files; keep the samples + docs.
knowledge/portfolios/*
!knowledge/portfolios/.gitkeep
!knowledge/portfolios/README.md
!knowledge/portfolios/sample_portfolio.csv
!knowledge/portfolios/banking_portfolio.csv

# Backtest outputs (generated equity curves + reports).
backtesting/results/

# --- OS / editor noise --------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
